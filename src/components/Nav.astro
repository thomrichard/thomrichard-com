---
interface Props { active?: string }
const { active = '' } = Astro.props;

const items = [
  { id: 'diag', label: 'Diag-IA', href: '/diag-ia' },
  { id: 'sur-mesure', label: 'Sur-mesure', href: '/sur-mesure' },
  { id: 'portfolio', label: 'Portfolio', href: '/portfolio' },
  { id: 'building-public', label: 'Building public', href: '/build-in-public' },
];
---
<header class="tr-nav">
  <div class="tr-nav__inner">
    <a href="/" class="tr-nav__brand">
      <span class="tr-nav__mark">TR</span>
      <div>
        <div class="tr-nav__name">Thomas Richard</div>
        <div class="tr-nav__sub">AUTOMATION · IA</div>
      </div>
    </a>

    <nav class="tr-nav__links" id="tr-nav-links" aria-label="Navigation principale">
      {items.map(it => (
        <a href={it.href} class={`tr-nav__link ${active === it.id ? 'tr-nav__link--active' : ''}`}>
          {it.label}
        </a>
      ))}
      <a href="https://tidycal.com/thomrichard/diagia-decouverte" target="_blank" rel="noopener" class="tr-nav__cta--mobile">Réserver le Diag-IA →</a>
    </nav>

    <a href="https://tidycal.com/thomrichard/diagia-decouverte" target="_blank" rel="noopener" class="tr-nav__cta">Réserver le Diag-IA →</a>

    <button type="button" class="tr-nav__burger" id="tr-nav-burger" aria-label="Menu" aria-expanded="false" aria-controls="tr-nav-links">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
    </button>
  </div>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById('tr-nav-burger');
    const menu = document.getElementById('tr-nav-links');
    if (!btn || !menu) return;
    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    // Ferme le menu si on clique sur un lien (cas du SPA-like, ou pour propreté)
    menu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        menu.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
      });
    });
  })();
</script>
