---
interface Props {
  name: 'arrow-right' | 'check' | 'x' | 'map' | 'route' | 'zap' | 'calculator' | 'wrench' | 'calendar' | 'shield' | 'users' | 'mail' | 'trending-up' | 'file-text' | 'settings' | 'clock' | 'sparkles';
  class?: string;
}
const { name, class: className = 'tr-icon' } = Astro.props;
---
{name === 'arrow-right' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
)}
{name === 'check' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
)}
{name === 'x' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
)}
{name === 'map' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="M9 5 3 7v14l6-2 6 2 6-2V5l-6 2-6-2zM9 5v14M15 7v14"/></svg>
)}
{name === 'wrench' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 0 0 5.4-5.4l-2.5 2.5-2.5-2.5z"/></svg>
)}
{name === 'trending-up' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
)}
{name === 'users' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
)}
{name === 'mail' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
)}
{name === 'shield' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
)}
{name === 'calendar' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
)}
{name === 'clock' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
)}
{name === 'sparkles' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="m12 3-1.5 4.5L6 9l4.5 1.5L12 15l1.5-4.5L18 9l-4.5-1.5L12 3zM5 16l-.75 2.25L2 19l2.25.75L5 22l.75-2.25L8 19l-2.25-.75L5 16zM19 13l-.75 2.25L16 16l2.25.75L19 19l.75-2.25L22 16l-2.25-.75L19 13z"/></svg>
)}
{name === 'zap' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z"/></svg>
)}
{name === 'route' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><circle cx="6" cy="19" r="3"/><circle cx="18" cy="5" r="3"/><path d="M9 19h7a3 3 0 0 0 0-6H8a3 3 0 0 1 0-6h7"/></svg>
)}
{name === 'calculator' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/></svg>
)}
{name === 'file-text' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>
)}
{name === 'settings' && (
  <svg class={className} viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="3"/></svg>
)}
